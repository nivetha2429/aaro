{
  "name": "aaro-tests",
  "version": "1.0.0",
  "description": "End-to-end test suite for AARO Systems e-commerce platform",
  "scripts": {
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:headed": "npx playwright test --headed",
    "test:chrome": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:mobile": "npx playwright test --project='Pixel 5' --project='iPhone 13' --project='Galaxy S21'",
    "test:api": "npx playwright test tests/api/",
    "test:e2e": "npx playwright test tests/e2e/",
    "test:admin": "npx playwright test tests/e2e/04-admin-products.spec.ts tests/e2e/05-admin-tabs.spec.ts",
    "test:fast": "npx playwright test --project=chromium tests/e2e/01-homepage.spec.ts tests/e2e/02-shop-pages.spec.ts",
    "health": "node health-check.js",
    "report": "npx playwright show-report",
    "install:browsers": "npx playwright install"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0"
  }
}
